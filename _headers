# _headers - Put this in your root folder (same place as index.html)
/*
  Content-Security-Policy: default-src * data: blob: https: http: ws: wss: 'unsafe-inline' 'unsafe-eval'; script-src * data: blob: https: http: 'unsafe-inline' 'unsafe-eval' https://js.paystack.co https://checkout.paystack.com https://*.paystack.com; style-src * 'unsafe-inline' https://*.paystack.com; frame-src * https://checkout.paystack.com; connect-src * https: http:;
  X-Frame-Options: ALLOWALL
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, OPTIONS